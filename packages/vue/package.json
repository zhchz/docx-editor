{
  "name": "@eigenpal/docx-editor-vue",
  "version": "1.0.3",
  "description": "Vue 3 DOCX editor adapter for @eigenpal/docx-editor-core.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs"
    },
    "./composables": {
      "types": "./dist/composables/index.d.ts",
      "import": "./dist/composables.js",
      "require": "./dist/composables.cjs"
    },
    "./dialogs": {
      "types": "./dist/components/dialogs/index.d.ts",
      "import": "./dist/dialogs.js",
      "require": "./dist/dialogs.cjs"
    },
    "./plugin-api": {
      "types": "./dist/plugin-api/index.d.ts",
      "import": "./dist/plugin-api.js",
      "require": "./dist/plugin-api.cjs"
    },
    "./styles": {
      "types": "./dist/styles/index.d.ts",
      "import": "./dist/styles.js",
      "require": "./dist/styles.cjs"
    },
    "./styles.css": "./dist/docx-editor-vue.css"
  },
  "typesVersions": {
    "*": {
      "ui": [
        "./dist/ui.d.ts"
      ],
      "composables": [
        "./dist/composables/index.d.ts"
      ],
      "dialogs": [
        "./dist/components/dialogs/index.d.ts"
      ],
      "plugin-api": [
        "./dist/plugin-api/index.d.ts"
      ],
      "styles": [
        "./dist/styles/index.d.ts"
      ]
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && node ../../scripts/inject-package-doc.mjs --package @eigenpal/docx-editor-vue",
    "typecheck": "tsc --noEmit",
    "api:extract": "node ../../scripts/api-extractor.mjs --package @eigenpal/docx-editor-vue --local",
    "api:check": "node ../../scripts/api-extractor.mjs --package @eigenpal/docx-editor-vue"
  },
  "peerDependencies": {
    "prosemirror-commands": "^1.5.2",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-history": "^1.4.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.19.4",
    "prosemirror-state": "^1.4.3",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.6",
    "vue": "^3.3.0"
  },
  "dependencies": {
    "@eigenpal/docx-editor-agents": "^1.0.3",
    "@eigenpal/docx-editor-core": "^1.0.3",
    "@eigenpal/docx-editor-i18n": "^1.0.3"
  },
  "keywords": [
    "docx",
    "editor",
    "vue",
    "word",
    "document"
  ],
  "author": {
    "name": "Jedr Blaszyk",
    "email": "jedr@eigenpal.com",
    "url": "https://github.com/jedrazb"
  },
  "license": "Apache-2.0",
  "homepage": "https://docx-editor.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/eigenpal/docx-editor.git",
    "directory": "packages/vue"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "prosemirror-history": "^1.4.0",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.41.6",
    "vite-plugin-dts": "^5.0.0"
  }
}
