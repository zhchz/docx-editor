{
  "name": "@eigenpal/docx-editor-agents",
  "version": "1.0.3",
  "description": "Agent SDK and chat UI for the DOCX editor — framework-agnostic bridge, MCP server, AI SDK adapters, plus React UI (and Vue UI in 1.x)",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.mjs",
      "require": "./dist/bridge.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.mjs",
      "require": "./dist/mcp.js"
    },
    "./ai-sdk/server": {
      "types": "./dist/ai-sdk/server.d.ts",
      "import": "./dist/ai-sdk/server.mjs",
      "require": "./dist/ai-sdk/server.js"
    },
    "./ai-sdk/react": {
      "types": "./dist/ai-sdk/react.d.ts",
      "import": "./dist/ai-sdk/react.mjs",
      "require": "./dist/ai-sdk/react.js"
    },
    "./ai-sdk/vue": {
      "types": "./dist/ai-sdk/vue.d.ts",
      "import": "./dist/ai-sdk/vue.mjs",
      "require": "./dist/ai-sdk/vue.js"
    }
  },
  "typesVersions": {
    "*": {
      "bridge": [
        "./dist/bridge.d.ts"
      ],
      "server": [
        "./dist/server.d.ts"
      ],
      "react": [
        "./dist/react.d.ts"
      ],
      "vue": [
        "./dist/vue.d.ts"
      ],
      "mcp": [
        "./dist/mcp.d.ts"
      ],
      "ai-sdk/server": [
        "./dist/ai-sdk/server.d.ts"
      ],
      "ai-sdk/react": [
        "./dist/ai-sdk/react.d.ts"
      ],
      "ai-sdk/vue": [
        "./dist/ai-sdk/vue.d.ts"
      ]
    }
  },
  "peerDependencies": {
    "@ai-sdk/vue": "^2.0.0",
    "ai": "^5.0.0 || ^6.0.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/vue": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.50.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "ai": "^6.0.169",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && vite build && node ../../scripts/inject-package-doc.mjs --package @eigenpal/docx-editor-agents",
    "typecheck": "vue-tsc --noEmit",
    "api:extract": "node ../../scripts/api-extractor.mjs --package @eigenpal/docx-editor-agents --local",
    "api:check": "node ../../scripts/api-extractor.mjs --package @eigenpal/docx-editor-agents"
  },
  "dependencies": {
    "docxtemplater": "^3.50.0",
    "jszip": "^3.10.1",
    "pizzip": "^3.1.7",
    "xml-js": "^1.6.11"
  },
  "keywords": [
    "docx",
    "ai",
    "agent",
    "review",
    "track-changes",
    "comments",
    "legal",
    "contract"
  ],
  "author": {
    "name": "Jedr Blaszyk",
    "email": "jedr@eigenpal.com",
    "url": "https://github.com/jedrazb"
  },
  "license": "Apache-2.0",
  "homepage": "https://docx-editor.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/eigenpal/docx-editor.git",
    "directory": "packages/agents"
  },
  "publishConfig": {
    "access": "public"
  }
}
