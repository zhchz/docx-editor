{
  "name": "@eigenpal/docx-editor-agents",
  "version": "0.5.1",
  "description": "Agent-friendly API for DOCX document review — read, comment, propose changes, accept/reject tracked changes",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.mjs",
      "require": "./dist/bridge.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.mjs",
      "require": "./dist/mcp.js"
    },
    "./ai-sdk/server": {
      "types": "./dist/ai-sdk/server.d.ts",
      "import": "./dist/ai-sdk/server.mjs",
      "require": "./dist/ai-sdk/server.js"
    },
    "./ai-sdk/react": {
      "types": "./dist/ai-sdk/react.d.ts",
      "import": "./dist/ai-sdk/react.mjs",
      "require": "./dist/ai-sdk/react.js"
    }
  },
  "typesVersions": {
    "*": {
      "bridge": [
        "./dist/bridge.d.ts"
      ],
      "server": [
        "./dist/server.d.ts"
      ],
      "react": [
        "./dist/react.d.ts"
      ],
      "mcp": [
        "./dist/mcp.d.ts"
      ],
      "ai-sdk/server": [
        "./dist/ai-sdk/server.d.ts"
      ],
      "ai-sdk/react": [
        "./dist/ai-sdk/react.d.ts"
      ]
    }
  },
  "peerDependencies": {
    "ai": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "ai": "^6.0.169"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "docxtemplater": "^3.50.0",
    "jszip": "^3.10.1",
    "pizzip": "^3.1.7",
    "xml-js": "^1.6.11"
  },
  "keywords": [
    "docx",
    "ai",
    "agent",
    "review",
    "track-changes",
    "comments",
    "legal",
    "contract"
  ],
  "author": "EigenPal",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://docx-editor.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/eigenpal/docx-editor.git",
    "directory": "packages/agent-use"
  },
  "publishConfig": {
    "access": "public"
  }
}
