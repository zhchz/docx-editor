{
  "name": "@eigenpal/docx-editor-i18n",
  "version": "1.0.3",
  "description": "Shared UI locale strings and types for the @eigenpal docx-editor adapters (React and Vue).",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./en": {
      "types": "./dist/en.d.ts",
      "import": "./dist/en.mjs",
      "require": "./dist/en.js"
    },
    "./de": {
      "types": "./dist/de.d.ts",
      "import": "./dist/de.mjs",
      "require": "./dist/de.js"
    },
    "./he": {
      "types": "./dist/he.d.ts",
      "import": "./dist/he.mjs",
      "require": "./dist/he.js"
    },
    "./pl": {
      "types": "./dist/pl.d.ts",
      "import": "./dist/pl.mjs",
      "require": "./dist/pl.js"
    },
    "./pt-BR": {
      "types": "./dist/pt-BR.d.ts",
      "import": "./dist/pt-BR.mjs",
      "require": "./dist/pt-BR.js"
    },
    "./tr": {
      "types": "./dist/tr.d.ts",
      "import": "./dist/tr.mjs",
      "require": "./dist/tr.js"
    },
    "./zh-CN": {
      "types": "./dist/zh-CN.d.ts",
      "import": "./dist/zh-CN.mjs",
      "require": "./dist/zh-CN.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node ../../scripts/inject-package-doc.mjs --package @eigenpal/docx-editor-i18n",
    "typecheck": "tsc --noEmit",
    "api:extract": "node ../../scripts/api-extractor.mjs --package @eigenpal/docx-editor-i18n --local",
    "api:check": "node ../../scripts/api-extractor.mjs --package @eigenpal/docx-editor-i18n"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "docx",
    "editor",
    "i18n",
    "locales",
    "translations"
  ],
  "author": {
    "name": "Jedr Blaszyk",
    "email": "jedr@eigenpal.com",
    "url": "https://github.com/jedrazb"
  },
  "license": "Apache-2.0",
  "homepage": "https://docx-editor.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/eigenpal/docx-editor.git",
    "directory": "packages/i18n"
  },
  "publishConfig": {
    "access": "public"
  }
}
